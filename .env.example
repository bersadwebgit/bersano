# =====================================================
# .env.example — این فایل به گیت push می‌شود
# فایل .env واقعی را از روی این بسازید و هرگز push نکنید
# =====================================================

# ----- PostgreSQL -----
DB_USER=shop_admin
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# ----- Redis -----
REDIS_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# ----- Redis HTTP Proxy Token -----
SRH_TOKEN=CHANGE_THIS_TO_STRONG_TOKEN

# ----- Next.js / App -----
NEXTAUTH_SECRET=CHANGE_THIS_TO_STRONG_SECRET
NEXTAUTH_URL=https://bersana.ir

# ----- OpenRouter AI -----
OPENROUTER_API_KEY=

# ----- Pexels (تصاویر) -----
PEXELS_API_KEY=

# ----- Super Admin -----
SUPER_ADMIN_SECRET=CHANGE_THIS_TO_STRONG_SECRET

# ----- SMS Panel (ملی‌پایامک سیستمی پلتفرم) -----
MELIPAYAMAK_USERNAME=
MELIPAYAMAK_PASSWORD=
MELIPAYAMAK_PATTERN_CODE=
SMS_ENCRYPTION_KEY=

