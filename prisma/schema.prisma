  productId  String   @map("product_id")
  variantId  String?  @map("variant_id")
  phone      String
  isNotified Boolean  @default(false) @map("is_notified")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shopId])
  @@index([productId])
  @@index([variantId])
}

model SystemTicket {
  id            String   @id @default(cuid())
  shopId        String   @map("shop_id")
  subject       String
  description   String
  status        String   @default("new") // 'new', 'in_progress', 'answered', 'closed'
  priority      String   @default("normal") // 'low', 'normal', 'high', 'urgent'
  attachmentUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages SystemTicketMessage[]

  @@index([shopId])
}

model SystemTicketMessage {
  id            String       @id @default(cuid())
  ticketId      String
  ticket        SystemTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId      String // tenant admin user id or "superadmin"
  senderRole    String // 'admin' or 'superadmin'
  message       String
  attachmentUrl String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

