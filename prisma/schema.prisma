  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformBlogCategory {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  posts       PlatformBlogPost[]
}

model PlatformBlogTag {
