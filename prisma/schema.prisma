  @@index([postId])
  @@index([tagId])
}

model AiChangeSet {
  id            String         @id @default(cuid())
  shopId        String         @map("shop_id")
  prompt        String         @db.Text
  status        String         @default("pending") // pending, approved, executing, completed, failed, cancelled, rolled_back
  riskLevel     String         @default("low") @map("risk_level") // low, medium, high
  riskAnalysis  String?        @map("risk_analysis") @db.Text
  summary       String?        @db.Text
  steps         AiChangeStep[]
  approvals     AiApproval[]
  feedback      AiFeedback[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  executedAt    DateTime?      @map("executed_at")
  rolledBackAt  DateTime?      @map("rolled_back_at")
  rollbackNotes String?        @map("rollback_notes") @db.Text

  @@index([shopId])
  @@index([status])
  @@index([createdAt])
}

model AiChangeStep {
  id           String      @id @default(cuid())
  changeSetId  String      @map("change_set_id")
  changeSet    AiChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)
  action       String // create, update, delete
  modelName    String      @map("model_name") // e.g. Product, Category, etc.
  recordId     String?     @map("record_id") // Target record ID
  beforeValue  Json?       @map("before_value") // For rollback
  afterValue   Json?       @map("after_value") // Proposed value
  status       String      @default("pending") // pending, completed, failed, rolled_back
  errorMessage String?     @map("error_message") @db.Text
  order        Int         @default(0)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([changeSetId])
  @@index([recordId])
}

model AiApproval {
  id          String      @id @default(cuid())
  changeSetId String      @map("change_set_id")
  changeSet   AiChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)
  userId      String      @map("user_id")
  approved    Boolean
  notes       String?     @db.Text
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([changeSetId])
  @@index([userId])
}

model AiFeedback {
  id          String      @id @default(cuid())
  changeSetId String      @map("change_set_id")
  changeSet   AiChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)
  userId      String?     @map("user_id")
  rating      Int // 1 to 5 stars
  comment     String?     @db.Text
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([changeSetId])
}

model AiPromptVersion {
  id        String   @id @default(cuid())
  name      String   @unique // Unique name of the prompt (e.g. "product_planner")
  version   Int      @default(1)
  content   String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([name, isActive])
}

// =====================================================================
// Marketing CMS (platform brand website) — hybrid architecture.
// SystemSetting keeps global singletons (announcement, contact, tracking).
// These models hold structured, versionable, previewable page content.
// Scope: platform marketing site only (NOT tenant storefronts).
// =====================================================================

model MarketingPage {
  id            String  @id @default(cuid())
  slug          String  @unique // e.g. "home", "about", "pricing"
  title         String
  status        String  @default("draft") // draft | published | scheduled | archived
  // SEO
  metaTitle     String? @db.Text
  metaDesc      String? @db.Text
  canonicalUrl  String?
  ogImage       String?
  noindex       Boolean @default(false)
  structuredData String? @db.Text // optional raw JSON-LD, validated/sanitized before publish

  publishedAt   DateTime?
  scheduledAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sections  MarketingSection[]
  revisions MarketingRevision[]

  @@index([status])
  @@index([slug, status])
}

model MarketingSection {
  id           String  @id @default(cuid())
  pageId       String
  page         MarketingPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type         String // hero | featureGrid | pricing | comparison | faq | cta | trustBar | richText | ...
  order        Int     @default(0)
  enabled      Boolean @default(true)
  content      Json    @default("{}") // JSONB: section-specific fields
  themeVariant String  @default("surface") // surface | muted | inverse
  anchorId     String? // in-page anchor
  visibility   String  @default("all") // all | desktop | mobile

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([pageId])
  @@index([pageId, order])
}

model MarketingRevision {
  id         String  @id @default(cuid())
  pageId     String
  page       MarketingPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  snapshot   Json // full serialized page + sections at capture time
  label      String? // "autosave" | "publish" | custom
  isAutosave Boolean @default(false)
  authorId   String?
  authorName String?
  createdAt  DateTime @default(now())

  @@index([pageId])
  @@index([pageId, createdAt])
}

model MarketingRedirect {
  id         String  @id @default(cuid())
  fromPath   String  @unique
  toPath     String
  statusCode Int     @default(301) // 301 | 302 | 307 | 308
  enabled    Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enabled])
}

model MediaAsset {
  id         String  @id @default(cuid())
  url        String
  type       String  @default("image") // image | video
  name       String
  alt        String?
  width      Int?
  height     Int?
  size       Int? // bytes
  mime       String?
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

model MarketingAuditLog {
  id        String  @id @default(cuid())
  actorId   String?
  actorName String?
  action    String // create | update | publish | rollback | delete | schedule
  entity    String // page | section | plan | redirect | media | settings
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([createdAt])
}

model MarketingPlan {
  id           String  @id @default(cuid())
  key          String  @unique // e.g. "start" | "professional" | "growth"
  name         String
  description  String? @db.Text
  audience     String? // who it's for
  priceLabel   String  @default("") // display price, supports "رایگان"
  period       String  @default("") // "تومان / ماهانه"
  annualPriceLabel String @default("")
  badge        String?
  ctaText      String  @default("شروع کنید")
  ctaLink      String  @default("/register")
  features     Json    @default("[]") // string[]
  highlighted  Boolean @default(false)
  isActive     Boolean @default(true)
  order        Int     @default(0)
  // Optional link to the billing Package that this display plan maps to
  packageId    String?
  package      Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, order])
}
