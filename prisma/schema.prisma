  title              String
  slug               String                @unique
  excerpt            String?
  content            String                @db.Text
  coverImage         String?
  status             String                @default("draft") // draft, published, scheduled
  categoryId         String?
  category           PlatformBlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author             String?
  publishedAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  readingTime        Int                   @default(0)
  canonicalUrl       String?
  metaTitle          String?
  metaDescription    String?
