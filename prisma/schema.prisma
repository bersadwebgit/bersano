  redirectWww       Boolean   @default(true) // redirect non-www to www or www to non-www
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([shopId])
  @@index([domain])
}

model ShopSeedProfile {
