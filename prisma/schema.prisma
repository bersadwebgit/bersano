  @@index([senderId])
}

model Package {
  id        String   @id @default(cuid())
  name      String
  months    Int      @default(1)
  price     Float    @default(0)
  features  String // JSON string representing enabled features
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shopSettings  ShopSettings[]
  marketingPlans MarketingPlan[]
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id        String        @id @default(cuid())
  shopId    String        @map("shop_id")
  name      String?
  phone     String?
  email     String?
  status    String        @default("active") // "active", "closed"
  mode      String        @default("ai") // "ai", "manual"
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([shopId])
  @@index([phone])
  @@index([status])
}

model ChatMessage {
  id          String      @id @default(cuid())
  shopId      String      @map("shop_id")
  sessionId   String      @map("session_id")
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender      String // "customer", "ai", "admin"
  message     String      @db.Text
  messageType String      @default("text") @map("message_type") // "text", "product", "article"
  metadata    String?     @db.Text // JSON string for product/article details
  isRead      Boolean     @default(false) @map("is_read")
  createdAt   DateTime    @default(now())

  @@index([shopId])
  @@index([sessionId])
}

model WholesaleRequest {
  id           String   @id @default(cuid())
  shopId       String   @map("shop_id")
  userId       String
  companyName  String
  businessType String
  phone        String
  description  String?
  status       String   @default("pending") // pending, approved, rejected
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([shopId])
  @@index([userId])
}

model AiUsage {
  id        String   @id @default(cuid())
  shopId    String   @map("shop_id")
  endpoint  String
  tokensIn  Int      @default(0) @map("tokens_in")
  tokensOut Int      @default(0) @map("tokens_out")
  costUsd   Float    @default(0) @map("cost_usd")
  model     String?
  monthKey  String   @map("month_key") // e.g. "2026-06"
  createdAt DateTime @default(now()) @map("created_at")

  // AI-008 (Phase C): durable usage/billing enrichment. All nullable + additive so legacy rows
  // (operationType=null) keep counting toward the chat quota exactly as before.
  operationType  String?  @map("operation_type") // 'chat' | 'embedding'
  resolvedModel  String?  @map("resolved_model") // the model actually sent to the provider (AI-004)
  status         String?  // 'success' | 'failed' | 'quota_exceeded'
  costStatus     String?  @map("cost_status") // 'resolved' | 'unresolved' | 'unknown'
  costUsdDecimal Decimal? @map("cost_usd_decimal") @db.Decimal(14, 8) // precise billing currency
  requestId      String?  @map("request_id")
  durationMs     Int?     @map("duration_ms")
  inputCount     Int?     @map("input_count") // embedding: number of inputs in the (batch) request
  idempotencyKey String?  @map("idempotency_key") // prevents duplicate usage on retry/resume

  // Attempt-level tracking additions
  rootRequestId     String?  @map("root_request_id")
  attemptIndex      Int?     @default(0) @map("attempt_index")
  providerRequestId String?  @map("provider_request_id")
  usageKnown        Boolean? @default(true) @map("usage_known")
  actualCost        Decimal? @map("actual_cost") @db.Decimal(14, 8)
  estimatedCost     Decimal? @map("estimated_cost") @db.Decimal(14, 8)
  errorCode         String?  @map("error_code")
  transportMode     String?  @map("transport_mode")

  @@unique([shopId, idempotencyKey, operationType, attemptIndex])
  @@index([shopId])
  @@index([shopId, monthKey])
  @@index([shopId, operationType, monthKey])
}

model ShopDomain {
  id                String    @id @default(cuid())
  shopId            String    @map("shop_id")
  domain            String    @unique
  isPrimary         Boolean   @default(false)
  isVerified        Boolean   @default(false)
  verificationType  String    @default("TXT") // TXT or CNAME
